msgid "TLS Certificate Error"
msgstr "TLS-Zertifikatsfehler"

msgid "TLS error — see dialog for details"
msgstr "TLS-Fehler – Details im Dialog"

msgid "If your Fritz!Box uses a self-signed certificate you can enable\n\"Ignore TLS certificate warnings\" in the connection dialog."
msgstr ""
"Falls Ihre Fritz!Box ein selbstsigniertes Zertifikat verwendet, koennen Sie\n"
"\"TLS-Zertifikatswarnungen ignorieren\" im Verbindungsdialog aktivieren."

msgid "A TLS/SSL certificate error occurred while connecting to %1:\n\n%2\n\n%3"
msgstr ""
"Beim Verbinden mit %1 ist ein TLS/SSL-Zertifikatsfehler aufgetreten:\n"
"\n"
"%2\n"
"\n"
"%3"

